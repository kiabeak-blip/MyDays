rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own user -> family/member mapping
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /families/{familyId} {
      // Any signed-in user can read family settings (needed to look up
      // a family by invite code before joining, and to load family data).
      allow read: if request.auth != null;

      // Anyone signed in can create a family, becoming its owner.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // Only the owner can update family-level settings.
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      allow delete: if false;

      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }

      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
